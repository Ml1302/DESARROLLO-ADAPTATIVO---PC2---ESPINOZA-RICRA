@page "/"

<PageTitle>Inicio – BancoArboleda</PageTitle>

<div class="hero">
    <h1>¡Bienvenido a BancoArboleda!</h1>
    <p>Tu banco digital de confianza – rápido, seguro y fácil</p>
</div>

<div class="page-wrapper">
    <div class="card">
        <div class="card__title">¿Qué deseas hacer hoy?</div>
        <div class="option-grid">

            <!--  HU-01: Opción 1 — ACTIVA -->
            <a href="recarga/paso1" class="option-card" id="btn-recarga">
                <div class="option-card__icon">📱</div>
                <div class="option-card__body">
                    <h3>Recarga Celular</h3>
                    <p>Recarga tu saldo móvil al instante</p>
                </div>
                <span class="option-card__arrow">›</span>
            </a>

            <!--  HU-01: Opción 2 — DESHABILITADA (Próximamente) -->
            <div class="option-card option-card--disabled"
                 id="btn-pago-servicio"
                 aria-disabled="true"
                 title="Próximamente disponible">
                <div class="option-card__icon">💡</div>
                <div class="option-card__body">
                    <h3>Pago de Servicio</h3>
                    <p>Luz, agua, gas y más</p>
                </div>
                <span class="badge badge-pronto">Próximamente</span>
            </div>

            <!--  HU-01: Opción 3 — DESHABILITADA (Próximamente) -->
            <div class="option-card option-card--disabled"
                 id="btn-transferencia"
                 aria-disabled="true"
                 title="Próximamente disponible">
                <div class="option-card__icon">🔄</div>
                <div class="option-card__body">
                    <h3>Transferencia entre mis cuentas</h3>
                    <p>Mueve dinero entre tus cuentas</p>
                </div>
                <span class="badge badge-pronto">Próximamente</span>
            </div>

        </div>
    </div>

    <div class="info-box" style="margin-top:1.25rem">
        <span class="info-box__icon">ℹ️</span>
        <div>
            <strong>Horario de operaciones:</strong> Las 24 horas del día, los 7 días de la semana.
            Tus recargas se procesan de forma inmediata.
        </div>
    </div>
</div>
