@page "/recarga/paso1"
@inject NavigationManager NavigationManager
@inject RecargaFlowState FlowState
@inject OperadorService OperadorService
@using System.ComponentModel.DataAnnotations

<PageTitle>Recarga – Paso 1</PageTitle>

<div class="page-wrapper">
    <!-- Indicador de pasos -->
    <div class="step-indicator" style="gap:.5rem;">
        <div class="step-indicator__item active">
            <div class="step-indicator__dot">1</div>
            <div class="step-indicator__label">Destino</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">2</div>
            <div class="step-indicator__label">Monto</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">3</div>
            <div class="step-indicator__label">Clave</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Listo</div>
        </div>
    </div>

    <div class="card">
        <div class="card__title">Número y Operador</div>

        @if (apiConnectionError)
        {
            <div class="alert alert-error" role="alert" style="margin-bottom: 1.25rem;">
                <span class="alert-icon">⚠️</span>
                <div>
                    <strong>Servidor fuera de línea:</strong> No se pudo conectar con el servidor de Backend. 
                    Actualmente la aplicación funciona únicamente en modo de demostración del Frontend (fuera de línea).
                </div>
            </div>
        }

        <EditForm Model="this" OnValidSubmit="OnValidSubmitAsync" novalidate>
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label" for="numero-celular">
                    Número de celular <span class="required">*</span>
                </label>
                <InputText id="numero-celular"
                           @bind-Value="NumeroCelular"
                           class="form-control"
                           placeholder="Ej: 987654321"
                           maxlength="9"
                           inputmode="numeric"
                           autocomplete="tel"
                           onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                           disabled="@apiConnectionError" />
                <ValidationMessage For="@(() => NumeroCelular)" class="form-error" />
                <div style="font-size:.78rem; color:var(--color-text-muted); margin-top:.35rem;">
                    Solo números · Exactamente 9 dígitos · Debe comenzar con 9
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="operador-select">
                    Operador <span class="required">*</span>
                </label>
                <InputSelect id="operador-select"
                             @bind-Value="OperadorId"
                             class="form-control"
                             disabled="@apiConnectionError">
                    @if (apiConnectionError)
                    {
                        <option value="">— No se pudieron cargar los operadores —</option>
                    }
                    else
                    {
                        <option value="">— Selecciona un operador —</option>
                        @foreach (var op in operadores)
                        {
                            <option value="@op.Id">@op.Nombre</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => OperadorId)" class="form-error" />
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-primary" id="btn-siguiente-paso1" disabled="@apiConnectionError">
                    Continuar &rarr;
                </button>
                <a href="/" class="btn btn-secondary" id="btn-cancelar-paso1">Cancelar</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private string numeroCelular = string.Empty;
    private bool apiConnectionError = false;

    [Required(ErrorMessage = "El número de celular es obligatorio.")]
    [RegularExpression(@"^9\d{8}$", ErrorMessage = "El número debe tener exactamente 9 dígitos y comenzar con 9.")]
    public string NumeroCelular
    {
        get => numeroCelular;
        set => numeroCelular = new string(value.Where(char.IsDigit).Take(9).ToArray());
    }

    [Required(ErrorMessage = "Debe seleccionar un operador.")]
    public int? OperadorId { get; set; }

    private IEnumerable<Operador> operadores = Array.Empty<Operador>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            apiConnectionError = false;
            operadores = await OperadorService.GetAllAsync();
            
            if (operadores == null || !operadores.Any())
            {
                apiConnectionError = true;
            }
            else
            {
                // Pre-cargar si el usuario ya ingresó datos previamente
                if (!string.IsNullOrEmpty(FlowState.NumeroCelular))
                {
                    NumeroCelular = FlowState.NumeroCelular;
                }
                if (FlowState.OperadorId.HasValue)
                {
                    OperadorId = FlowState.OperadorId;
                }
            }
        }
        catch (Exception ex)
        {
            apiConnectionError = true;
            Console.WriteLine($"Error al cargar operadores: {ex.Message}");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var op = operadores.FirstOrDefault(o => o.Id == OperadorId);
        if (op != null)
        {
            FlowState.NumeroCelular = NumeroCelular;
            FlowState.OperadorId = OperadorId;
            FlowState.OperadorNombre = op.Nombre;
            FlowState.MontoMin = op.MontoMin;
            FlowState.MontoMax = op.MontoMax;

            NavigationManager.NavigateTo("recarga/paso2");
        }
        await Task.CompletedTask;
    }
}

