@page
@model BancoArboleda.Pages.Recarga.Paso3Model
@{
    ViewData["Title"] = "Recarga – Paso 3";
}

<div class="page-wrapper">
    <!-- Indicador de pasos -->
    <div class="step-indicator" style="gap:.5rem;">
        <div class="step-indicator__item done">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Destino</div>
        </div>
        <div class="step-connector done"></div>
        <div class="step-indicator__item done">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Monto</div>
        </div>
        <div class="step-connector done"></div>
        <div class="step-indicator__item active">
            <div class="step-indicator__dot">3</div>
            <div class="step-indicator__label">Clave</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Listo</div>
        </div>
    </div>

    <!-- Resumen de la operación -->
    <div class="info-box">
        <span class="info-box__icon">💳</span>
        <div>
            Recarga de <strong>S/@Model.Monto</strong> a
            <strong>@Model.NumeroCelular</strong>
            (@Model.OperadorNombre)
        </div>
    </div>

    <div class="card">
        <div class="card__title">Ingresa tu Clave Online</div>

        @if (!ModelState.IsValid && ModelState.ErrorCount > 0)
        {
            <div class="alert alert-error" role="alert">
                <span class="alert-icon">⚠️</span>
                <div>
                    @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" for="clave-input">
                    Clave online (6 dígitos) <span class="required">*</span>
                </label>
                <input id="clave-input"
                       type="password"
                       name="ClaveOnline"
                       class="form-control @(ModelState["ClaveOnline"]?.Errors.Any() == true ? "is-invalid" : "")"
                       placeholder="••••••"
                       maxlength="6"
                       pattern="[0-9]{6}"
                       inputmode="numeric"
                       autocomplete="current-password"
                       required
                       style="letter-spacing:.3rem; font-size:1.2rem; text-align:center;" />

                <!-- Indicador visual PIN -->
                <div class="pin-hint" id="pin-dots" aria-hidden="true">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="pin-dot" id="pin-dot-@i"></div>
                    }
                </div>

                @if (ModelState["ClaveOnline"]?.Errors.Any() == true)
                {
                    <div class="form-error">
                        @ModelState["ClaveOnline"]!.Errors.First().ErrorMessage
                    </div>
                }
                <div style="font-size:.78rem; color:var(--color-text-muted); margin-top:.35rem; text-align:center;">
                    🔒 Tu clave es cifrada y nunca se almacena
                </div>
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-primary" id="btn-confirmar">
                    ✓ Confirmar Recarga
                </button>
                <a href="/Recarga/Paso2" class="btn btn-secondary" id="btn-atras-paso3">← Atrás</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const claveInput = document.getElementById('clave-input');
    const dots = Array.from(document.querySelectorAll('.pin-dot'));

    // Solo dígitos
    claveInput.addEventListener('input', function () {
        this.value = this.value.replace(/\D/g, '').slice(0, 6);
        const len = this.value.length;
        dots.forEach((d, i) => {
            d.style.background = i < len ? 'var(--color-primary)' : 'transparent';
            d.style.borderColor = i < len ? 'var(--color-primary)' : 'var(--color-border)';
        });
    });

    claveInput.addEventListener('keypress', function (e) {
        if (!/[0-9]/.test(e.key)) e.preventDefault();
    });
</script>
}
