@page
@model BancoArboleda.Pages.Recarga.Paso2Model
@{
    ViewData["Title"] = "Recarga – Paso 2";
}

<div class="page-wrapper">
    <!-- Indicador de pasos -->
    <div class="step-indicator" style="gap:.5rem;">
        <div class="step-indicator__item done">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Destino</div>
        </div>
        <div class="step-connector done"></div>
        <div class="step-indicator__item active">
            <div class="step-indicator__dot">2</div>
            <div class="step-indicator__label">Monto</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">3</div>
            <div class="step-indicator__label">Clave</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Listo</div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="info-box">
        <span class="info-box__icon">📱</span>
        <div>
            Recargando <strong>@Model.NumeroCelular</strong>
            con <strong>@Model.OperadorNombre</strong>
            · Rango: S/@Model.MontoMin.ToString("F2") – S/@Model.MontoMax.ToString("F2")
        </div>
    </div>

    <div class="card">
        <div class="card__title">Selecciona el Monto</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMonto) || (ModelState["Monto"]?.Errors.Any() == true))
        {
            <div class="alert alert-error" role="alert">
                <span class="alert-icon">⚠️</span>
                <span>@(Model.ErrorMonto ?? ModelState["Monto"]!.Errors.First().ErrorMessage)</span>
            </div>
        }

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Botones rápidos -->
            <div class="form-group">
                <label class="form-label">Montos rápidos</label>
                <div class="monto-grid">
                    @foreach (var m in new[] { 5, 10, 20, 50 })
                    {
                        <button type="button"
                                class="btn-monto quick-monto"
                                data-value="@m"
                                id="btn-monto-@m">
                            S/@m
                        </button>
                    }
                </div>
            </div>

            <div class="divider">o ingresa otro monto</div>

            <div class="form-group">
                <label class="form-label" for="monto-libre">
                    Monto libre (S/) <span class="required">*</span>
                </label>
                <input id="monto-libre"
                       type="number"
                       name="Monto"
                       value="@Model.Monto"
                       class="form-control @(ModelState["Monto"]?.Errors.Any() == true ? "is-invalid" : "")"
                       placeholder="Ej: 15"
                       min="@Model.MontoMin.ToString("F2")"
                       max="@Model.MontoMax.ToString("F2")"
                       step="1"
                       inputmode="numeric"
                       required />
                <div style="font-size:.78rem; color:var(--color-text-muted); margin-top:.35rem;">
                    Mínimo: S/@Model.MontoMin.ToString("F2") · Máximo: S/@Model.MontoMax.ToString("F2")
                </div>
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-primary" id="btn-siguiente-paso2">
                    Continuar &rarr;
                </button>
                <a href="/Recarga/Paso1" class="btn btn-secondary" id="btn-atras-paso2">← Atrás</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const inputMonto = document.getElementById('monto-libre');
    const btns = document.querySelectorAll('.quick-monto');

    // Clic en botón rápido → rellenar input
    btns.forEach(btn => {
        btn.addEventListener('click', function () {
            inputMonto.value = this.dataset.value;
            btns.forEach(b => b.classList.remove('selected'));
            this.classList.add('selected');
            inputMonto.focus();
        });
    });

    // Marcar botón si el input coincide
    inputMonto.addEventListener('input', function () {
        const v = parseFloat(this.value);
        btns.forEach(b => b.classList.toggle('selected', parseFloat(b.dataset.value) === v));
    });

    // Sólo números enteros positivos
    inputMonto.addEventListener('keypress', function (e) {
        if (!/[0-9]/.test(e.key)) e.preventDefault();
    });
</script>
}
