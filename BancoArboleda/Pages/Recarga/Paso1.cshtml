@page
@model BancoArboleda.Pages.Recarga.Paso1Model
@{
    ViewData["Title"] = "Recarga – Paso 1";
}

<div class="page-wrapper">
    <!-- Indicador de pasos -->
    <div class="step-indicator" style="gap:.5rem;">
        <div class="step-indicator__item active">
            <div class="step-indicator__dot">1</div>
            <div class="step-indicator__label">Destino</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">2</div>
            <div class="step-indicator__label">Monto</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">3</div>
            <div class="step-indicator__label">Clave</div>
        </div>
        <div class="step-connector"></div>
        <div class="step-indicator__item">
            <div class="step-indicator__dot">✓</div>
            <div class="step-indicator__label">Listo</div>
        </div>
    </div>

    <div class="card">
        <div class="card__title">Número y Operador</div>

        @if (!ModelState.IsValid && ModelState.ErrorCount > 0)
        {
            <div class="alert alert-error" role="alert">
                <span class="alert-icon">⚠️</span>
                <div>
                    @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" for="numero-celular">
                    Número de celular <span class="required">*</span>
                </label>
                <input id="numero-celular"
                       type="tel"
                       name="NumeroCelular"
                       value="@Model.NumeroCelular"
                       class="form-control @(ModelState["NumeroCelular"]?.Errors.Any() == true ? "is-invalid" : "")"
                       placeholder="Ej: 987654321"
                       maxlength="9"
                       pattern="[0-9]*"
                       inputmode="numeric"
                       autocomplete="tel"
                       required />
                @if (ModelState["NumeroCelular"]?.Errors.Any() == true)
                {
                    <div class="form-error">
                        @ModelState["NumeroCelular"]!.Errors.First().ErrorMessage
                    </div>
                }
                <div style="font-size:.78rem; color:var(--color-text-muted); margin-top:.35rem;">
                    Solo números · Exactamente 9 dígitos · Debe comenzar con 9
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="operador-select">
                    Operador <span class="required">*</span>
                </label>
                <select id="operador-select"
                        name="OperadorId"
                        class="form-control @(ModelState["OperadorId"]?.Errors.Any() == true ? "is-invalid" : "")"
                        required>
                    <option value="">— Selecciona un operador —</option>
                    @foreach (var op in Model.Operadores)
                    {
                        if (Model.OperadorId.ToString() == op.Value)
                        {
                            <option value="@op.Value" selected>@op.Text</option>
                        }
                        else
                        {
                            <option value="@op.Value">@op.Text</option>
                        }
                    }
                </select>
                @if (ModelState["OperadorId"]?.Errors.Any() == true)
                {
                    <div class="form-error">
                        @ModelState["OperadorId"]!.Errors.First().ErrorMessage
                    </div>
                }
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-primary" id="btn-siguiente-paso1">
                    Continuar &rarr;
                </button>
                <a href="/" class="btn btn-secondary" id="btn-cancelar-paso1">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Solo permitir dígitos en el campo número
    const input = document.getElementById('numero-celular');
    if (input) {
        input.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 9);
        });
        input.addEventListener('keypress', function (e) {
            if (!/[0-9]/.test(e.key)) e.preventDefault();
        });
    }
</script>
}
